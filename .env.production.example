# =================================================================
#  G-REQUETES — Variables d'environnement PRODUCTION
#
#  1. Copier ce fichier : cp .env.production.example .env
#  2. Modifier les valeurs marquées (*** A CHANGER ***)
#  3. Lancer : docker compose up -d
#
#  IMPORTANT : ne pas mettre de commentaires (#) sur les lignes
#              de valeurs — Docker les inclurait dans la valeur.
# =================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME="G-REQUETES IUG"
APP_ENV=production
# Laisser vide : l'APP_KEY est generee automatiquement au 1er demarrage
APP_KEY=
APP_DEBUG=false
# *** A CHANGER : mettre l'IP ou le domaine de la machine
APP_URL=http://localhost:8080
# Port expose sur la machine hote (changer si 8080 est deja utilise)
APP_PORT=8080

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de donnees ───────────────────────────────────────────────
DB_CONNECTION=mysql
# Ne pas modifier DB_HOST : c'est le nom du service Docker
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sygre_db
DB_USERNAME=sygre_user
# *** A CHANGER : choisir un mot de passe fort
DB_PASSWORD=MotDePasseForte2025!
# *** A CHANGER : choisir un mot de passe root fort
DB_ROOT_PASSWORD=RootPassForte2025!

# ── Cache / Sessions / Queues ────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Redis ────────────────────────────────────────────────────────
# Ne pas modifier REDIS_HOST : c'est le nom du service Docker
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail SMTP ────────────────────────────────────────────────────
MAIL_MAILER=smtp
# *** A CHANGER : serveur SMTP de l'IUG
MAIL_HOST=smtp.votre-serveur.cm
MAIL_PORT=587
# *** A CHANGER
MAIL_USERNAME=noreply@iug.cm
# *** A CHANGER
MAIL_PASSWORD=MotDePasseMail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@iug.cm
MAIL_FROM_NAME="G-REQUETES IUG"

# ── Stockage ─────────────────────────────────────────────────────
FILESYSTEM_DISK=local

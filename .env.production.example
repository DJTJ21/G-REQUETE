APP_NAME="G-REQUÊTES"
APP_ENV=production
APP_KEY=base64:CHANGEZ_MOI_GENEREZ_AVEC_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://VOTRE_IP_OU_DOMAINE:8080

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de données ──────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=sygre_db
DB_USERNAME=sygre_user
DB_PASSWORD=MotDePasseForte2025!
DB_ROOT_PASSWORD=RootPassForte2025!

# ── Cache & Sessions ─────────────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (remplacez par votre serveur SMTP réel) ─────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-fournisseur.com
MAIL_PORT=587
MAIL_USERNAME=noreply@votre-domaine.cm
MAIL_PASSWORD=MotDePasseMail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@votre-domaine.cm
MAIL_FROM_NAME="G-REQUÊTES IUG"

# ── Stockage fichiers ────────────────────────────────────────────
FILESYSTEM_DISK=local

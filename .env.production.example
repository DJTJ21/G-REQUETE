# =================================================================
#  G-REQUETES — Variables d'environnement PRODUCTION
#  Copier ce fichier en .env et remplir les valeurs marquées (***)
# =================================================================

# ── Application ───────────────────────────────────────────────────
APP_NAME="G-REQUETES IUG"
APP_ENV=production
APP_KEY=                          # Laissez vide → généré automatiquement au 1er démarrage
APP_DEBUG=false
APP_URL=http://localhost:8080     # *** Remplacer par l'IP ou domaine réel

APP_PORT=8080                     # Port exposé sur la machine hôte

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Base de données ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db                        # Ne pas modifier (nom du service Docker)
DB_PORT=3306
DB_DATABASE=sygre_db
DB_USERNAME=sygre_user
DB_PASSWORD=MotDePasseForte2025!  # *** Changer en production
DB_ROOT_PASSWORD=RootPassForte2025! # *** Changer en production

# ── Cache / Sessions / Queues ─────────────────────────────────────
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis                  # Ne pas modifier (nom du service Docker)
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail SMTP ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.votre-serveur.cm   # *** Remplacer par le serveur SMTP de l'IUG
MAIL_PORT=587
MAIL_USERNAME=noreply@iug.cm      # *** Remplacer
MAIL_PASSWORD=MotDePasseMail      # *** Remplacer
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@iug.cm
MAIL_FROM_NAME="G-REQUETES IUG"

# ── Stockage ──────────────────────────────────────────────────────
FILESYSTEM_DISK=local
